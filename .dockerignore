# Build context is always the repo root (all three apps share this file).
# Keep it tight so `turbo prune --docker` has a small context to work with.

**/node_modules
**/.turbo
**/dist
**/dist-ssr
**/.output
**/.tanstack
**/build

# Prisma generated client (regenerated inside the image)
apps/api/src/generated

# TanStack Router codegen (regenerated at build time)
**/routeTree.gen.ts

# Local env / secrets — injected at runtime via env_file, not baked in
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.*.local

# VCS / editor / OS
.git
.gitignore
.vscode
.idea
.cursor
.agents
.DS_Store

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Misc docs (keep top-level README so images self-document if needed)
*.md
!README.md
