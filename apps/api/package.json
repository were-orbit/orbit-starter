{
  "name": "@orbit/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --import tsx src/index.ts",
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:reset": "prisma migrate reset --force",
    "db:seed": "prisma db seed",
    "drizzle:generate": "drizzle-kit generate --config=drizzle/drizzle.config.ts",
    "drizzle:migrate": "drizzle-kit migrate --config=drizzle/drizzle.config.ts",
    "drizzle:push": "drizzle-kit push --config=drizzle/drizzle.config.ts",
    "drizzle:studio": "drizzle-kit studio --config=drizzle/drizzle.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.5",
    "@better-auth/prisma-adapter": "^1.6.5",
    "@hono/node-server": "^1.13.7",
    "@hono/node-ws": "^1.3.0",
    "@orbit/shared": "*",
    "@polar-sh/sdk": "^0.47.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@react-email/components": "^1.0.12",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.20.0",
    "@unkey/ratelimit": "^2.1.4",
    "@upstash/qstash": "^2.10.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "better-auth": "^1.6.5",
    "dodopayments": "^2.28.2",
    "dotenv": "^17.2.0",
    "evlog": "^2.13.0",
    "graphile-worker": "^0.16.6",
    "hono": "^4.6.14",
    "livekit-server-sdk": "^2.15.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "resend": "^6.12.1",
    "stripe": "^22.0.2",
    "uploadthing": "^7.7.4",
    "uuid": "^14.0.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.0",
    "prisma": "^7.7.0",
    "prisma-generator-drizzle": "^0.7.6",
    "tsx": "^4.19.2",
    "typescript": "~6.0.2",
    "vitest": "^4.1.4"
  }
}
